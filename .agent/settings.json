{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "MultiEdit",
      "Write",
      "Bash",
      "Grep",
      "Glob",
      "Agent",
      "Task"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(DROP *)",
      "Bash(DELETE FROM *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(ssh *)",
      "Bash(> /dev/*)"
    ]
  },
  "hooks": {
    "context_warnings": true,
    "workflow_guard": false,
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .agent/hooks/gsd-check-update.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .agent/hooks/gsd-prompt-guard.js",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node .agent/hooks/gsd-workflow-guard.js",
            "timeout": 5
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node .agent/hooks/gsd-context-monitor.js",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .agent/hooks/session-stop-audit.js",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
