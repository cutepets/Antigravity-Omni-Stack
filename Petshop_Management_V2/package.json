{
  "name": "petshop-management-v2",
  "private": true,
  "version": "2.5.1",
  "description": "Petshop Service Management System v2 - Turborepo Monorepo",
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@petshop/api",
    "dev:web": "turbo run dev --filter=@petshop/web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "ui:editor": "node scripts/react-rewrite-workspace.mjs 3000",
    "audit:daily": "pnpm lint && pnpm type-check && pnpm utf8:check && pnpm version:check && pnpm audit:generated-artifacts && git diff --check",
    "audit:generated-artifacts": "node scripts/audit-generated-artifacts.mjs",
    "version:check": "node scripts/check-version-hardcode.mjs",
    "utf8:check": "node scripts/check-utf8.mjs",
    "utf8:check:staged": "node scripts/check-utf8.mjs --staged",
    "clean": "turbo run clean && rimraf node_modules",
    "db:generate": "turbo run db:generate --filter=@petshop/database",
    "db:migrate": "turbo run db:migrate --filter=@petshop/database",
    "db:migrate:prod": "pnpm --filter @petshop/database db:migrate:prod",
    "db:status": "pnpm --filter @petshop/database db:status",
    "db:validate": "pnpm --filter @petshop/database db:validate",
    "db:push": "pnpm --filter @petshop/database db:push",
    "db:seed": "pnpm --filter @petshop/database db:seed",
    "db:studio": "pnpm --filter @petshop/database db:studio",
    "db:reset": "pnpm --filter @petshop/database db:reset",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "rimraf": "^6.0.1",
    "turbo": "^2.9.6",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "msw": {
    "workerDirectory": [
      "apps\\web\\public"
    ]
  },
  "pnpm": {
    "overrides": {
      "lodash": ">=4.18.0",
      "picomatch": ">=4.0.4",
      "path-to-regexp": ">=8.4.0",
      "js-yaml": ">=4.1.1"
    }
  }
}
