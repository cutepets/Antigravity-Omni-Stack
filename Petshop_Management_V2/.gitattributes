# Git attributes — normalize line endings and mark text files as UTF-8
# This prevents Windows from converting LF→CRLF which breaks UTF-8 detection

# ── Default: normalize all text files to LF on commit ─────────────
*           text=auto eol=lf

# ── Source code ───────────────────────────────────────────────────
*.ts        text eol=lf working-tree-encoding=UTF-8
*.tsx       text eol=lf working-tree-encoding=UTF-8
*.js        text eol=lf working-tree-encoding=UTF-8
*.jsx       text eol=lf working-tree-encoding=UTF-8
*.mjs       text eol=lf working-tree-encoding=UTF-8
*.cjs       text eol=lf working-tree-encoding=UTF-8

# ── Config / Data files ───────────────────────────────────────────
*.json      text eol=lf working-tree-encoding=UTF-8
*.yml       text eol=lf working-tree-encoding=UTF-8
*.yaml      text eol=lf working-tree-encoding=UTF-8
*.prisma    text eol=lf working-tree-encoding=UTF-8
*.env       text eol=lf working-tree-encoding=UTF-8
*.md        text eol=lf working-tree-encoding=UTF-8
*.sql       text eol=lf working-tree-encoding=UTF-8
*.py        text eol=lf working-tree-encoding=UTF-8

# ── Shell scripts ─────────────────────────────────────────────────
*.sh        text eol=lf
*.bash      text eol=lf

# ── Binary files — never touch ────────────────────────────────────
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.webp      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.mp4       binary
*.mp3       binary
