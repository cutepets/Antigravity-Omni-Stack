# ============================================
# PETSHOP SERVICE — Production Environment
# ============================================
# Copy to .env on the VPS and fill in real values.

NODE_ENV=production

# ---- Database (internal Docker network) ----
POSTGRES_USER=petshop
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=petshop_db
DATABASE_URL="postgresql://petshop:CHANGE_ME_strong_password_here@postgres:5432/petshop_db"

# ---- JWT (generate with: openssl rand -base64 48) ----
JWT_SECRET="CHANGE_ME_generate_random_64_chars"
JWT_REFRESH_SECRET="CHANGE_ME_generate_another_random_64_chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ---- App secret encryption (generate with: openssl rand -base64 48) ----
# Required when saving encrypted settings such as Google OAuth client secret.
# Keep this value stable after deploy. Changing it will make previously saved secrets unreadable.
APP_SECRET_ENCRYPTION_KEY="CHANGE_ME_generate_random_64_chars"

# ---- Server Ports ----
API_PORT=3001
WEB_PORT=3000

# ---- Redis (internal Docker network) ----
REDIS_URL="redis://redis:6379"

# ---- CORS ----
CORS_ORIGINS="https://app.petshophanoi.com"
PUBLIC_API_URL="https://app.petshophanoi.com"
PUBLIC_WEB_URL="https://app.petshophanoi.com"

# ---- Google Login (optional; can also be configured from Settings UI) ----
# If you configure Google from the UI, APP_SECRET_ENCRYPTION_KEY is still required.
GOOGLE_AUTH_ENABLED=false
GOOGLE_AUTH_CLIENT_ID=""
GOOGLE_AUTH_CLIENT_SECRET=""
GOOGLE_AUTH_ALLOWED_DOMAIN=""

# ---- Upload ----
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=52428800
