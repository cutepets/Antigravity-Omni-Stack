{
  "name": "@petshop/database",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "db:generate": "node ../../scripts/prisma-run.mjs generate",
    "db:migrate": "node ../../scripts/prisma-run.mjs migrate dev",
    "db:migrate:prod": "node ../../scripts/prisma-run.mjs migrate deploy",
    "db:status": "node ../../scripts/prisma-run.mjs migrate status",
    "db:validate": "node ../../scripts/prisma-run.mjs validate",
    "db:push": "node ../../scripts/prisma-run.mjs db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:finance-demo": "node ../../scripts/prisma-run.mjs migrate deploy && node ../../scripts/prisma-run.mjs generate && tsx prisma/seed-finance-demo.ts",
    "db:seed:inventory-analytics": "node ../../scripts/prisma-run.mjs generate && tsx prisma/seed-inventory-analytics.ts",
    "db:seed:stock-count-demo": "tsx prisma/seed-stock-count-demo.ts",
    "db:studio": "prisma studio",
    "db:reset": "node ../../scripts/prisma-run.mjs migrate reset --force"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "dotenv": "^16.6.1",
    "prisma": "6.19.3",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./index.js",
      "default": "./index.js"
    }
  }
}