// =============================================================================
// @file     schema.prisma — Petshop Management V2 Database Schema
// @encoding utf-8  ← This file and ALL seed/migration files MUST be UTF-8.
//                    AI tools: always open with encoding='utf-8'.
//                    Never save as Latin-1 / cp1252 / Windows-1252.
// @db       PostgreSQL — collation UTF-8 is enforced at the server level.
//           String fields storing Vietnamese text use TEXT / VARCHAR,
//           which inherits the database-level UTF-8 collation.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Branch {
  id                    String                 @id @default(cuid())
  code                  String                 @unique
  name                  String
  address               String?
  phone                 String?
  email                 String?
  description           String?
  logo                  String?
  taxCode               String?
  openTime              String?                @default("08:00")
  closeTime             String?                @default("21:00")
  isMain                Boolean                @default(false)
  isActive              Boolean                @default(true)
  cashReserveTargetAmount Float                @default(2000000)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  branchStocks          BranchStock[]
  customers             Customer[]
  groomingSessions      GroomingSession[]
  hotelStays            HotelStay[]
  orders                Order[]
  pets                  Pet[]
  shiftSessions         ShiftSession[]
  cashVaultEntries      CashVaultEntry[]
  stockReceipts         StockReceipt[]
  stockReceiptReceives  StockReceiptReceive[]
  supplierPayments      SupplierPayment[]
  supplierReturns       SupplierReturn[]
  supplierReturnRefunds SupplierReturnRefund[]
  productSalesDaily     ProductSalesDaily[]
  paymentIntents        PaymentIntent[]
  transactions          Transaction[]
  users                 User[]
  authorizedUsers       User[]                 @relation("UserAuthorizedBranches")
  stockCountSessions    StockCountSession[]
  hotelPriceRules       HotelPriceRule[]

  @@map("branches")
}

model User {
  id                    String                 @id @default(cuid())
  staffCode             String                 @unique
  username              String                 @unique
  passwordHash          String
  fullName              String
  legacyRole            StaffRole              @default(STAFF) @map("role")
  roleId                String?
  status                StaffStatus            @default(WORKING)
  employmentType        EmploymentType         @default(FULL_TIME)
  phone                 String?
  email                 String?
  address               String?
  avatar                String?
  gender                String?
  dob                   DateTime?
  identityCode          String?
  emergencyContactTitle String?
  emergencyContactPhone String?
  shiftStart            String?
  shiftEnd              String?
  baseSalary            Float?
  spaCommissionRate     Float?
  branchId              String?
  joinDate              DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  activityLogs          ActivityLog[]
  groomingSessions      GroomingSession[]
  hotelCreatedStays     HotelStay[]
  orders                Order[]
  refreshTokens         RefreshToken[]
  shiftSessions         ShiftSession[]
  cashVaultEntries      CashVaultEntry[]     @relation("CashVaultEntryPerformedBy")
  stockReceiptReceives  StockReceiptReceive[]
  supplierPayments      SupplierPayment[]
  supplierReturns       SupplierReturn[]
  supplierReturnRefunds SupplierReturnRefund[]
  transactions          Transaction[]
  branch                Branch?                @relation(fields: [branchId], references: [id])
  role                  Role?                  @relation(fields: [roleId], references: [id])
  authorizedBranches    Branch[]               @relation("UserAuthorizedBranches")
  documents             EmployeeDocument[]
  stockCountSessions    StockCountSession[]    @relation("StockCountSessionCreatedBy")
  approvedStockCountSessions StockCountSession[] @relation("StockCountSessionApprovedBy")
  stockCountShiftSessions StockCountShiftSession[] @relation("StockCountShiftCountedBy")
  approvedOrders          Order[]              @relation("OrderApprover")
  stockExportOrders       Order[]              @relation("OrderStockExporter")
  settledOrders           Order[]              @relation("OrderSettler")
  orderTimelines          OrderTimeline[]

  @@map("users")
}

// ============================================================================
// Employee Document Management
// ============================================================================

model EmployeeDocument {
  id          String   @id @default(cuid())
  userId      String
  type        DocumentType
  fileName    String
  fileUrl     String
  fileSize    Int      // in bytes
  mimeType    String
  description String?
  uploadedAt  DateTime @default(now())
  uploadedBy  String
  expiresAt   DateTime?
  isActive    Boolean  @default(true)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([isActive])
  @@map("employee_documents")
}

enum DocumentType {
  CCCD_FRONT          // CCCD mặt trước
  CCCD_BACK           // CCCD mặt sau
  APPLICATION         // Hồ sơ xin việc
  CERTIFICATE         // Bằng cấp / Chứng chỉ
  CONTRACT            // Hợp đồng lao động
  HEALTH_CERT         // Giấy khám sức khỏe
  TRAINING_CERT       // Chứng chỉ đào tạo
  OTHER               // Tài liệu khác
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model CustomerGroup {
  id          String     @id @default(cuid())
  name        String     @unique
  color       String     @default("#6366f1")
  pricePolicy String     @default("Giá lẻ")
  discount    Float      @default(0)
  description String?
  isActive    Boolean    @default(true)
  isDefault   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  customers   Customer[]

  @@map("customer_groups")
}

model Customer {
  id           String         @id @default(cuid())
  customerCode String         @unique
  fullName     String
  phone        String         @unique
  email        String?
  address      String?
  tier         CustomerTier   @default(BRONZE)
  points       Int            @default(0)
  pointsUsed   Int            @default(0)
  branchId     String?
  groupId      String?
  notes        String?
  taxCode      String?
  description  String?
  debt         Float          @default(0)
  totalSpent   Float          @default(0)
  totalOrders  Int            @default(0)
  isActive     Boolean        @default(true)
  isSupplier   Boolean        @default(false)
  supplierCode String?        @unique
  companyName         String?
  companyAddress      String?
  representativeName  String?
  representativePhone String?
  bankAccount         String?
  bankName            String?
  createdAt           DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  branch       Branch?        @relation(fields: [branchId], references: [id])
  group        CustomerGroup? @relation(fields: [groupId], references: [id])
  hotelStays   HotelStay[]
  orders       Order[]
  pets         Pet[]

  @@index([phone])
  @@index([customerCode])
  @@index([branchId])
  @@index([isActive])
  @@map("customers")
}

model Pet {
  id               String            @id @default(cuid())
  petCode          String            @unique
  name             String
  species          String
  breed            String?
  gender           PetGender         @default(UNKNOWN)
  dateOfBirth      DateTime?
  weight           Float?
  color            String?
  microchipId      String?
  avatar           String?
  notes            String?
  branchId         String?
  customerId       String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  allergies        String?
  isActive         Boolean           @default(true)
  temperament      String?
  groomingSessions GroomingSession[]
  hotelStays       HotelStay[]
  healthNotes      PetHealthNote[]
  vaccinations     PetVaccination[]
  weightLogs       PetWeightLog[]
  branch           Branch?           @relation(fields: [branchId], references: [id])
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([customerId])
  @@index([petCode])
  @@map("pets")
}

model PetWeightLog {
  id        String   @id @default(cuid())
  petId     String
  weight    Float
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@map("pet_weight_logs")
}

model PetVaccination {
  id          String    @id @default(cuid())
  petId       String
  vaccineName String
  date        DateTime
  nextDueDate DateTime?
  notes       String?
  photoUrl    String?
  createdAt   DateTime  @default(now())
  pet         Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@map("pet_vaccinations")
}

model PetHealthNote {
  id        String   @id @default(cuid())
  petId     String
  content   String
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@map("pet_health_notes")
}

model Product {
  id                  String                    @id @default(cuid())
  name                String
  sku                 String?                   @unique
  barcode             String?                   @unique
  category            String?
  targetSpecies       String?
  brand               String?
  description         String?
  price               Float
  costPrice           Float?
  minStock            Int                       @default(5)
  unit                String                    @default("cái")
  image               String?
  isActive            Boolean                   @default(true)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  attributes          String?
  conversionRate      Float?
  conversionUnit      String?
  deletedAt           DateTime?
  importName          String?
  supplierId          String?
  tags                String?
  vat                 Float                     @default(0)
  weight              Float?
  wholesalePrice      Float?
  lastCountShift      StockCountShift?        // Ca kiểm gần nhất đã gán
  branchStocks        BranchStock[]
  orderItems          OrderItem[]
  variants            ProductVariant[]
  supplier            Supplier?                 @relation(fields: [supplierId], references: [id])
  receiptItems        StockReceiptItem[]
  receiveItems        StockReceiptReceiveItem[]
  salesDaily          ProductSalesDaily[]
  stockTransactions   StockTransaction[]
  supplierReturnItems SupplierReturnItem[]
  stockCountItems     StockCountItem[]

  @@index([sku])
  @@index([category])
  @@map("products")
}

model ProductVariant {
  id                  String                    @id @default(cuid())
  productId           String
  name                String
  sku                 String?                   @unique
  price               Float
  isActive            Boolean                   @default(true)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  barcode             String?
  conversions         String?
  costPrice           Float?
  deletedAt           DateTime?
  image               String?
  priceBookPrices     String?
  pricePolicies       String?
  branchStocks        BranchStock[]
  orderItems          OrderItem[]
  receiptItems        StockReceiptItem[]
  receiveItems        StockReceiptReceiveItem[]
  salesDaily          ProductSalesDaily[]
  supplierReturnItems SupplierReturnItem[]
  stockCountItems     StockCountItem[]
  stockTransactions   StockTransaction[]
  product             Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_variants")
}

model Service {
  id          String           @id @default(cuid())
  name        String
  code        String?          @unique
  type        ServiceType      @default(OTHER)
  description String?
  price       Float
  duration    Int?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  orderItems  OrderItem[]
  variants    ServiceVariant[]

  @@map("services")
}

model ServiceVariant {
  id         String      @id @default(cuid())
  serviceId  String
  name       String
  price      Float
  duration   Int?
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orderItems OrderItem[]
  service    Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("service_variants")
}

model Order {
  id               String            @id @default(cuid())
  orderNumber      String            @unique
  customerId       String?
  customerName     String
  staffId          String
  branchId         String?
  status           OrderStatus       @default(PENDING)
  paymentStatus    PaymentStatus     @default(UNPAID)
  subtotal         Float             @default(0)
  discount         Float             @default(0)
  shippingFee      Float             @default(0)
  total            Float             @default(0)
  paidAmount       Float             @default(0)
  remainingAmount  Float             @default(0)
  notes            String?
  createdAt        DateTime          @default(now())
  completedAt      DateTime?
  updatedAt        DateTime          @updatedAt

  // Workflow tracking fields
  approvedAt       DateTime?
  approvedBy       String?
  stockExportedAt  DateTime?
  stockExportedBy  String?
  settledAt        DateTime?
  settledBy        String?

  groomingSessions GroomingSession[]
  hotelStays       HotelStay[]
  items            OrderItem[]
  payments         OrderPayment[]
  paymentIntents   PaymentIntent[]
  bankTransactions BankTransaction[]
  webhookEvents    PaymentWebhookEvent[]
  timeline         OrderTimeline[]
  branch           Branch?           @relation(fields: [branchId], references: [id])
  customer         Customer?         @relation(fields: [customerId], references: [id])
  staff            User              @relation(fields: [staffId], references: [id])
  transactions     Transaction[]
  approvedByUser   User?             @relation("OrderApprover", fields: [approvedBy], references: [id])
  stockExportUser  User?             @relation("OrderStockExporter", fields: [stockExportedBy], references: [id])
  settledUser      User?             @relation("OrderSettler", fields: [settledBy], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([completedAt])
  @@index([approvedBy])
  @@index([stockExportedBy])
  @@index([settledBy])
  @@map("orders")
}

model OrderPayment {
  id        String   @id @default(cuid())
  orderId   String
  method    String
  amount    Float
  note      String?
  paymentAccountId    String?
  paymentAccountLabel String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([paymentAccountId])
  @@map("order_payments")
}

// ============================================================================
// Order Timeline / Lịch sử thay đổi đơn hàng
// ============================================================================

model OrderTimeline {
  id            String      @id @default(cuid())
  orderId       String
  action        OrderAction
  fromStatus    String?
  toStatus      String?
  note          String?
  performedBy   String
  metadata      Json?
  createdAt     DateTime    @default(now())

  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  performedByUser User      @relation(fields: [performedBy], references: [id])

  @@index([orderId])
  @@index([performedBy])
  @@index([createdAt])
  @@index([action])
  @@map("order_timelines")
}

model OrderItem {
  id                String           @id @default(cuid())
  orderId           String
  productId         String?
  productVariantId  String?
  serviceId         String?
  serviceVariantId  String?
  petId             String?
  groomingSessionId String?
  hotelStayId       String?
  description       String
  quantity          Float
  unitPrice         Float
  discountItem      Float            @default(0)
  vatRate           Float            @default(0)
  subtotal          Float
  pricingSnapshot   Json?
  type              String
  createdAt         DateTime         @default(now())
  groomingSession   GroomingSession? @relation(fields: [groomingSessionId], references: [id])
  hotelStay         HotelStay?       @relation(fields: [hotelStayId], references: [id])
  order             Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product?         @relation(fields: [productId], references: [id])
  productVariant    ProductVariant?  @relation(fields: [productVariantId], references: [id])
  service           Service?         @relation(fields: [serviceId], references: [id])
  serviceVariant    ServiceVariant?  @relation(fields: [serviceVariantId], references: [id])

  @@index([orderId])
  @@index([hotelStayId])
  @@map("order_items")
}

model ProductSalesDaily {
  id               String          @id @default(cuid())
  date             DateTime
  branchId         String?
  branchScope      String
  productId        String
  productVariantId String?
  salesKey         String
  quantitySold     Int             @default(0)
  revenue          Float           @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  branch           Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  product          Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  @@unique([date, branchScope, salesKey])
  @@index([branchId, date])
  @@index([productId, date])
  @@index([productVariantId, date])
  @@index([salesKey, date])
  @@map("product_sales_daily")
}

model GroomingSession {
  id          String         @id @default(cuid())
  sessionCode String         @unique
  petId       String
  petName     String
  customerId  String?
  branchId    String?
  staffId     String?
  serviceId   String?
  orderId     String?
  status      GroomingStatus @default(PENDING)
  startTime   DateTime?
  endTime     DateTime?
  notes       String?
  price       Float?
  surcharge   Float?         @default(0)
  packageCode String?
  weightAtBooking Float?
  weightBandId String?
  pricingSnapshot Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  branch      Branch?        @relation(fields: [branchId], references: [id])
  pet         Pet            @relation(fields: [petId], references: [id])
  order       Order?         @relation(fields: [orderId], references: [id])
  staff       User?          @relation(fields: [staffId], references: [id])
  weightBand  ServiceWeightBand? @relation(fields: [weightBandId], references: [id])
  orderItems  OrderItem[]

  @@index([branchId])
  @@index([petId])
  @@index([orderId])
  @@index([status])
  @@index([weightBandId])
  @@index([createdAt])
  @@map("grooming_sessions")
}

model ServiceWeightBand {
  id              String           @id @default(cuid())
  serviceType     ServiceType
  species         String?
  label           String
  minWeight       Float
  maxWeight       Float?
  sortOrder       Int              @default(0)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  spaPriceRules   SpaPriceRule[]
  groomingSessions GroomingSession[]
  hotelPriceRules HotelPriceRule[]
  hotelStays      HotelStay[]
  hotelChargeLines HotelStayChargeLine[]

  @@index([serviceType, species, isActive, sortOrder])
  @@map("service_weight_bands")
}

model HotelRateTable {
  id           String        @id @default(cuid())
  name         String
  year         Int
  species      String?
  minWeight    Float?
  maxWeight    Float?
  lineType     HotelLineType @default(REGULAR)
  ratePerNight Float
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  isActive     Boolean       @default(true)
  hotelStays   HotelStay[]

  @@index([year, lineType, isActive])
  @@map("hotel_rate_tables")
}

model Cage {
  id          String        @id @default(cuid())
  name        String        @unique
  type        HotelLineType @default(REGULAR)
  description String?
  position    Int           @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  hotelStays  HotelStay[]

  @@map("cages")
}

model HotelPriceRule {
  id            String            @id @default(cuid())
  sku           String?           // Editable SKU
  year          Int
  species       String?
  branchId      String?
  weightBandId  String
  dayType       HotelLineType     @default(REGULAR)
  halfDayPrice  Float
  fullDayPrice  Float
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  branch        Branch?           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  weightBand    ServiceWeightBand @relation(fields: [weightBandId], references: [id], onDelete: Cascade)

  @@index([year, branchId, dayType, species, isActive])
  @@index([weightBandId, year])
  @@map("hotel_price_rules")
}

model SpaPriceRule {
  id              String            @id @default(cuid())
  sku             String?           // Editable SKU
  species         String?
  packageCode     String
  weightBandId    String
  price           Float
  durationMinutes Int?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  weightBand      ServiceWeightBand @relation(fields: [weightBandId], references: [id], onDelete: Cascade)

  @@index([packageCode, species, isActive])
  @@index([weightBandId, packageCode])
  @@map("spa_price_rules")
}

model HolidayCalendarDate {
  id        String   @id @default(cuid())
  date      DateTime
  endDate   DateTime?
  name      String
  year      Int
  isRecurring Boolean @default(false)
  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date])
  @@index([year, isActive])
  @@index([isRecurring, isActive])
  @@index([date, endDate])
  @@map("holiday_calendar_dates")
}

model HotelStay {
  id                String          @id @default(cuid())
  petId             String
  petName           String
  customerId        String?
  cageId            String?
  createdById       String?
  checkIn           DateTime
  checkedInAt       DateTime?
  checkOut          DateTime?
  estimatedCheckOut DateTime?
  status            HotelStatus     @default(BOOKED)
  lineType          HotelLineType   @default(REGULAR)
  price             Float?
  paymentStatus     PaymentStatus   @default(UNPAID)
  notes             String?
  rateTableId       String?
  orderId           String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  stayCode          String?         @unique
  branchId          String?
  checkOutActual    DateTime?
  dailyRate         Float           @default(0)
  depositAmount     Float           @default(0)
  petNotes          String?
  weightAtBooking   Float?
  weightBandId      String?
  pricingSnapshot   Json?
  breakdownSnapshot Json?
  promotion         Float           @default(0)
  surcharge         Float           @default(0)
  slotIndex         Int?            // Vi tri o trong luoi so do
  accessories       String?         // Do di kem cua thu cung
  cancelledAt       DateTime?
  totalPrice        Float           @default(0)
  branch            Branch?         @relation(fields: [branchId], references: [id])
  cage              Cage?           @relation(fields: [cageId], references: [id])
  customer          Customer?       @relation(fields: [customerId], references: [id])
  createdBy         User?           @relation(fields: [createdById], references: [id])
  order             Order?          @relation(fields: [orderId], references: [id])
  pet               Pet             @relation(fields: [petId], references: [id])
  rateTable         HotelRateTable? @relation(fields: [rateTableId], references: [id])
  weightBand        ServiceWeightBand? @relation(fields: [weightBandId], references: [id])
  orderItems        OrderItem[]
  chargeLines       HotelStayChargeLine[]
  adjustments       HotelStayAdjustment[]

  @@index([petId])
  @@index([customerId])
  @@index([branchId])
  @@index([cageId])
  @@index([createdById])
  @@index([status])
  @@index([paymentStatus])
  @@index([orderId])
  @@index([weightBandId])
  @@index([checkIn])
  @@index([checkedInAt])
  @@index([estimatedCheckOut])
  @@index([cancelledAt])
  @@map("hotel_stays")
}

model HotelStayChargeLine {
  id              String             @id @default(cuid())
  hotelStayId     String
  weightBandId    String?
  label           String
  dayType         HotelLineType      @default(REGULAR)
  quantityDays    Float
  unitPrice       Float
  subtotal        Float
  sortOrder       Int                @default(0)
  pricingSnapshot Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  hotelStay       HotelStay          @relation(fields: [hotelStayId], references: [id], onDelete: Cascade)
  weightBand      ServiceWeightBand? @relation(fields: [weightBandId], references: [id], onDelete: SetNull)

  @@index([hotelStayId, sortOrder])
  @@index([dayType])
  @@index([weightBandId])
  @@map("hotel_stay_charge_lines")
}

model HotelStayAdjustment {
  id          String    @id @default(cuid())
  hotelStayId String
  type        String?
  label       String
  amount      Float
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  hotelStay   HotelStay @relation(fields: [hotelStayId], references: [id], onDelete: Cascade)

  @@index([hotelStayId, createdAt])
  @@map("hotel_stay_adjustments")
}

model Supplier {
  id            String            @id @default(cuid())
  code          String?           @unique
  name          String
  phone         String?
  email         String?
  address       String?
  avatar        String?
  notes         String?
  documents     Json?
  monthTarget   Float?
  yearTarget    Float?
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  debt          Float             @default(0)
  creditBalance Float             @default(0)
  products      Product[]
  stockReceipts StockReceipt[]
  payments      SupplierPayment[]
  returns       SupplierReturn[]

  @@map("suppliers")
}

model StockReceipt {
  id                  String                      @id @default(cuid())
  receiptNumber       String                      @unique
  supplierId          String?
  branchId            String?
  status              String                      @default("DRAFT")
  receiptStatus       String                      @default("DRAFT")
  paymentStatus       PaymentStatus               @default(UNPAID)
  totalAmount         Float                       @default(0)
  totalReceivedAmount Float                       @default(0)
  totalReturnedAmount Float                       @default(0)
  paidAmount          Float                       @default(0)
  notes               String?
  receivedAt          DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?
  shortClosedAt       DateTime?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  items               StockReceiptItem[]
  paymentAllocations  SupplierPaymentAllocation[]
  receiveEvents       StockReceiptReceive[]
  supplierReturns     SupplierReturn[]
  branch              Branch?                     @relation(fields: [branchId], references: [id])
  supplier            Supplier?                   @relation(fields: [supplierId], references: [id])

  @@index([branchId])
  @@index([supplierId])
  @@index([status])
  @@index([receiptStatus])
  @@index([paymentStatus])
  @@map("stock_receipts")
}

model StockReceiptItem {
  id               String                    @id @default(cuid())
  receiptId        String
  productId        String
  productVariantId String?
  quantity         Int
  receivedQuantity Int                       @default(0)
  returnedQuantity Int                       @default(0)
  closedQuantity   Int                       @default(0)
  unitPrice        Float
  totalPrice       Float
  createdAt        DateTime                  @default(now())
  receiveItems     StockReceiptReceiveItem[]
  returnItems      SupplierReturnItem[]
  product          Product                   @relation(fields: [productId], references: [id])
  productVariant   ProductVariant?           @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  receipt          StockReceipt              @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([productVariantId])
  @@index([receiptId])
  @@map("stock_receipt_items")
}

model StockReceiptReceive {
  id            String                    @id @default(cuid())
  receiveNumber String                    @unique
  receiptId     String
  branchId      String?
  staffId       String?
  notes         String?
  receivedAt    DateTime                  @default(now())
  totalQuantity Int                       @default(0)
  totalAmount   Float                     @default(0)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  receipt       StockReceipt              @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  branch        Branch?                   @relation(fields: [branchId], references: [id])
  staff         User?                     @relation(fields: [staffId], references: [id])
  items         StockReceiptReceiveItem[]

  @@index([receiptId])
  @@index([branchId])
  @@index([staffId])
  @@index([receivedAt])
  @@map("stock_receipt_receives")
}

model StockReceiptReceiveItem {
  id               String              @id @default(cuid())
  receiveId        String
  receiptItemId    String
  productId        String
  productVariantId String?
  quantity         Int
  unitPrice        Float
  totalPrice       Float
  createdAt        DateTime            @default(now())
  receive          StockReceiptReceive @relation(fields: [receiveId], references: [id], onDelete: Cascade)
  receiptItem      StockReceiptItem    @relation(fields: [receiptItemId], references: [id], onDelete: Cascade)
  product          Product             @relation(fields: [productId], references: [id])
  productVariant   ProductVariant?     @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  @@index([receiveId])
  @@index([receiptItemId])
  @@index([productId])
  @@index([productVariantId])
  @@map("stock_receipt_receive_items")
}

model SupplierPayment {
  id                  String                      @id @default(cuid())
  paymentNumber       String                      @unique
  supplierId          String
  branchId            String?
  staffId             String?
  transactionId       String?                     @unique
  targetReceiptId     String?
  targetReceiptNumber String?
  amount              Float
  appliedAmount       Float                       @default(0)
  unappliedAmount     Float                       @default(0)
