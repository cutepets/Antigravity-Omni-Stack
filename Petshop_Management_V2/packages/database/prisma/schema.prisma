enum CashbookCategoryType {
  INCOME
  EXPENSE
}

enum PaymentMethodType {
  CASH
  BANK
  EWALLET
  CARD
}

enum PaymentMethodColorKey {
  emerald
  sky
  amber
  orange
  violet
  rose
  cyan
  slate
}

enum PaymentQrProvider {
  VIETQR
}

enum PaymentIntentStatus {
  PENDING
  PAID
  EXPIRED
}

enum PaymentWebhookEventStatus {
  RECEIVED
  DUPLICATE
  UNMATCHED
  APPLIED
  IGNORED_ALREADY_PAID
  REJECTED
}

enum BankTransactionStatus {
  RECEIVED
  SUGGESTED
  APPLIED
  REVIEW
  DUPLICATE
  IGNORED
  REJECTED
}

enum BankTransactionClassification {
  UNCLASSIFIED
  SALES_PAYMENT
  SUPPLIER_PAYMENT
  CUSTOMER_CREDIT
  MANUAL_TRANSACTION
}

model CashbookCategory {
  id        String               @id @default(cuid())
  type      CashbookCategoryType
  name      String
  isActive  Boolean              @default(true)
  sortOrder Int                  @default(0)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@unique([type, name])
  @@index([type, isActive, sortOrder])
  @@map("cashbook_categories")
}

model BankTransferAccount {
  id            String   @id @default(cuid())
  name          String
  bankName      String
  accountNumber String   @unique
  accountHolder String
  notes         String?
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isDefault, isActive])
  @@index([bankName, isActive])
  @@map("bank_transfer_accounts")
}

model PaymentMethod {
  id            String            @id @default(cuid())
  code          String?           @unique
  name          String
  type          PaymentMethodType
  colorKey      PaymentMethodColorKey @default(emerald)
  isSystem      Boolean           @default(false)
  isDefault     Boolean           @default(false)
  isActive      Boolean           @default(true)
  sortOrder     Int               @default(0)
  minAmount     Float?
  maxAmount     Float?
  timeFrom      String?
  timeTo        String?
  weekdays      Int[]             @default([])
  branchIds     String[]          @default([])
  notes         String?
  bankName      String?
  accountNumber String?
  accountHolder String?
  qrEnabled     Boolean           @default(false)
  qrProvider    PaymentQrProvider?
  qrBankBin     String?
  qrTemplate    String?
  transferNotePrefix String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  paymentIntents PaymentIntent[]
  bankTransactions BankTransaction[]
  webhookEvents  PaymentWebhookEvent[]

  @@index([type, isActive, sortOrder])
  @@index([isDefault, isActive])
  @@map("payment_methods")
}

model PaymentIntent {
  id              String              @id @default(cuid())
  code            String              @unique
  orderId         String?
  branchId        String?
  paymentMethodId String
  amount          Float
  currency        String              @default("VND")
  status          PaymentIntentStatus @default(PENDING)
  provider        PaymentQrProvider?
  transferContent String
  qrUrl           String?
  qrPayload       String?
  metadata        Json?
  expiresAt       DateTime?
  paidAt          DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  branch          Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  order           Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)
  paymentMethod   PaymentMethod       @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict)
  webhookEvents   PaymentWebhookEvent[]
  bankTransactions BankTransaction[]

  @@index([orderId])
  @@index([branchId])
  @@index([paymentMethodId])
  @@index([status, expiresAt])
  @@map("payment_intents")
}

model BankTransaction {
  id                    String                        @id @default(cuid())
  provider              String
  sourceEventKey        String?
  dedupeKey             String
  externalEventId       String?
  externalTxnId         String?
  bankBin               String?
  accountNumber         String
  amount                Float
  currency              String                        @default("VND")
  direction             String                        @default("IN")
  description           String
  normalizedDescription String
  status                BankTransactionStatus         @default(RECEIVED)
  classification        BankTransactionClassification @default(UNCLASSIFIED)
  isTest                Boolean                       @default(false)
  sourceCount           Int                           @default(1)
  matchedPaymentIntentId String?
  matchedOrderId        String?
  matchedPaymentMethodId String?
  matchReason           String?
  note                  String?
  txnAt                 DateTime?
  processedAt           DateTime?
  rawPayload            Json?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  paymentIntent         PaymentIntent?                @relation(fields: [matchedPaymentIntentId], references: [id], onDelete: SetNull)
  order                 Order?                        @relation(fields: [matchedOrderId], references: [id], onDelete: SetNull)
  paymentMethod         PaymentMethod?                @relation(fields: [matchedPaymentMethodId], references: [id], onDelete: SetNull)
  webhookEvents         PaymentWebhookEvent[]

  @@index([provider, createdAt])
  @@index([sourceEventKey])
  @@index([dedupeKey])
  @@index([status, createdAt])
  @@index([classification, createdAt])
  @@index([isTest, createdAt])
  @@index([accountNumber, amount, createdAt])
  @@index([matchedPaymentIntentId])
  @@map("bank_transactions")
}

model PaymentWebhookEvent {
  id                    String                    @id @default(cuid())
  provider              String
  sourceEventKey        String?
  dedupeKey             String
  externalEventId       String?
  externalTxnId         String?
  bankBin               String?
  accountNumber         String
  amount                Float
  currency              String                    @default("VND")
  direction             String                    @default("IN")
  description           String
  normalizedDescription String
  status                PaymentWebhookEventStatus @default(RECEIVED)
  duplicateOfId         String?
  bankTransactionId     String?
  matchedPaymentIntentId String?
  matchedOrderId        String?
  matchedPaymentMethodId String?
  matchReason           String?
  note                  String?
  txnAt                 DateTime?
  processedAt           DateTime?
  rawPayload            Json
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  duplicateOf           PaymentWebhookEvent?      @relation("PaymentWebhookEventDuplicates", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates            PaymentWebhookEvent[]     @relation("PaymentWebhookEventDuplicates")
  bankTransaction       BankTransaction?          @relation(fields: [bankTransactionId], references: [id], onDelete: SetNull)
  paymentIntent         PaymentIntent?            @relation(fields: [matchedPaymentIntentId], references: [id], onDelete: SetNull)
  order                 Order?                    @relation(fields: [matchedOrderId], references: [id], onDelete: SetNull)
  paymentMethod         PaymentMethod?            @relation(fields: [matchedPaymentMethodId], references: [id], onDelete: SetNull)

  @@index([provider, createdAt])
  @@index([sourceEventKey])
  @@index([dedupeKey])
  @@index([status, createdAt])
  @@index([accountNumber, amount, createdAt])
  @@index([bankTransactionId])
  @@index([matchedPaymentIntentId])
  @@map("payment_webhook_events")
}

model PaymentWebhookSecret {
  id            String   @id @default(cuid())
  provider      String
  name          String
  secretHash    String
  secretPreview String
  lastUsedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([provider, name])
  @@index([provider, createdAt])
  @@index([secretHash])
  @@map("payment_webhook_secrets")
}

