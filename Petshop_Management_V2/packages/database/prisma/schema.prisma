generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id                    String                 @id @default(cuid())
  code                  String                 @unique
  name                  String
  address               String?
  phone                 String?
  email                 String?
  description           String?
  logo                  String?
  taxCode               String?
  openTime              String?                @default("08:00")
  closeTime             String?                @default("21:00")
  isMain                Boolean                @default(false)
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  branchStocks          BranchStock[]
  customers             Customer[]
  groomingSessions      GroomingSession[]
  hotelStays            HotelStay[]
  orders                Order[]
  pets                  Pet[]
  shiftSessions         ShiftSession[]
  stockReceipts         StockReceipt[]
  stockReceiptReceives  StockReceiptReceive[]
  supplierPayments      SupplierPayment[]
  supplierReturns       SupplierReturn[]
  supplierReturnRefunds SupplierReturnRefund[]
  transactions          Transaction[]
  users                 User[]
  authorizedUsers       User[]                 @relation("UserAuthorizedBranches")

  @@map("branches")
}

model User {
  id                    String                 @id @default(cuid())
  staffCode             String                 @unique
  username              String                 @unique
  passwordHash          String
  fullName              String
  legacyRole            StaffRole              @default(STAFF) @map("role")
  roleId                String?
  status                StaffStatus            @default(WORKING)
  employmentType        EmploymentType         @default(FULL_TIME)
  phone                 String?
  email                 String?
  address               String?
  avatar                String?
  gender                String?
  dob                   DateTime?
  identityCode          String?
  emergencyContactTitle String?
  emergencyContactPhone String?
  shiftStart            String?
  shiftEnd              String?
  baseSalary            Float?
  spaCommissionRate     Float?
  branchId              String?
  joinDate              DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  activityLogs          ActivityLog[]
  groomingSessions      GroomingSession[]
  orders                Order[]
  refreshTokens         RefreshToken[]
  shiftSessions         ShiftSession[]
  stockReceiptReceives  StockReceiptReceive[]
  supplierPayments      SupplierPayment[]
  supplierReturns       SupplierReturn[]
  supplierReturnRefunds SupplierReturnRefund[]
  transactions          Transaction[]
  branch                Branch?                @relation(fields: [branchId], references: [id])
  role                  Role?                  @relation(fields: [roleId], references: [id])
  authorizedBranches    Branch[]               @relation("UserAuthorizedBranches")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model CustomerGroup {
  id          String     @id @default(cuid())
  name        String     @unique
  color       String     @default("#6366f1")
  pricePolicy String     @default("Giá lẻ")
  discount    Float      @default(0)
  description String?
  isActive    Boolean    @default(true)
  isDefault   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  customers   Customer[]

  @@map("customer_groups")
}

model Customer {
  id           String         @id @default(cuid())
  customerCode String         @unique
  fullName     String
  phone        String         @unique
  email        String?
  address      String?
  tier         CustomerTier   @default(BRONZE)
  points       Int            @default(0)
  pointsUsed   Int            @default(0)
  branchId     String?
  groupId      String?
  notes        String?
  taxCode      String?
  description  String?
  debt         Float          @default(0)
  totalSpent   Float          @default(0)
  totalOrders  Int            @default(0)
  isActive     Boolean        @default(true)
  isSupplier   Boolean        @default(false)
  supplierCode String?        @unique
  companyName  String?
  bankAccount  String?
  bankName     String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  branch       Branch?        @relation(fields: [branchId], references: [id])
  group        CustomerGroup? @relation(fields: [groupId], references: [id])
  hotelStays   HotelStay[]
  orders       Order[]
  pets         Pet[]

  @@index([phone])
  @@index([customerCode])
  @@index([branchId])
  @@index([isActive])
  @@map("customers")
}

model Pet {
  id               String            @id @default(cuid())
  petCode          String            @unique
  name             String
  species          String
  breed            String?
  gender           PetGender         @default(UNKNOWN)
  dateOfBirth      DateTime?
  weight           Float?
  color            String?
  microchipId      String?
  avatar           String?
  notes            String?
  branchId         String?
  customerId       String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  allergies        String?
  isActive         Boolean           @default(true)
  temperament      String?
  groomingSessions GroomingSession[]
  hotelStays       HotelStay[]
  healthNotes      PetHealthNote[]
  vaccinations     PetVaccination[]
  weightLogs       PetWeightLog[]
  branch           Branch?           @relation(fields: [branchId], references: [id])
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([customerId])
  @@index([petCode])
  @@map("pets")
}

model PetWeightLog {
  id        String   @id @default(cuid())
  petId     String
  weight    Float
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@map("pet_weight_logs")
}

model PetVaccination {
  id          String    @id @default(cuid())
  petId       String
  vaccineName String
  date        DateTime
  nextDueDate DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  pet         Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@map("pet_vaccinations")
}

model PetHealthNote {
  id        String   @id @default(cuid())
  petId     String
  content   String
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@map("pet_health_notes")
}

model Product {
  id                  String                    @id @default(cuid())
  name                String
  sku                 String?                   @unique
  barcode             String?                   @unique
  category            String?
  targetSpecies       String?
  brand               String?
  description         String?
  price               Float
  costPrice           Float?
  minStock            Int                       @default(5)
  unit                String                    @default("cái")
  image               String?
  isActive            Boolean                   @default(true)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  attributes          String?
  conversionRate      Float?
  conversionUnit      String?
  deletedAt           DateTime?
  importName          String?
  supplierId          String?
  tags                String?
  vat                 Float                     @default(0)
  weight              Float?
  wholesalePrice      Float?
  branchStocks        BranchStock[]
  orderItems          OrderItem[]
  variants            ProductVariant[]
  supplier            Supplier?                 @relation(fields: [supplierId], references: [id])
  receiptItems        StockReceiptItem[]
  receiveItems        StockReceiptReceiveItem[]
  stockTransactions   StockTransaction[]
  supplierReturnItems SupplierReturnItem[]

  @@index([sku])
  @@index([category])
  @@map("products")
}

model ProductVariant {
  id                  String                    @id @default(cuid())
  productId           String
  name                String
  sku                 String?                   @unique
  price               Float
  isActive            Boolean                   @default(true)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  barcode             String?
  conversions         String?
  costPrice           Float?
  deletedAt           DateTime?
  image               String?
  priceBookPrices     String?
  pricePolicies       String?
  branchStocks        BranchStock[]
  orderItems          OrderItem[]
  receiptItems        StockReceiptItem[]
  receiveItems        StockReceiptReceiveItem[]
  supplierReturnItems SupplierReturnItem[]
  product             Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_variants")
}

model Service {
  id          String           @id @default(cuid())
  name        String
  code        String?          @unique
  type        ServiceType      @default(OTHER)
  description String?
  price       Float
  duration    Int?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  orderItems  OrderItem[]
  variants    ServiceVariant[]

  @@map("services")
}

model ServiceVariant {
  id         String      @id @default(cuid())
  serviceId  String
  name       String
  price      Float
  duration   Int?
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orderItems OrderItem[]
  service    Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("service_variants")
}

model Order {
  id               String            @id @default(cuid())
  orderNumber      String            @unique
  customerId       String?
  customerName     String
  staffId          String
  branchId         String?
  status           OrderStatus       @default(PENDING)
  paymentStatus    PaymentStatus     @default(UNPAID)
  subtotal         Float             @default(0)
  discount         Float             @default(0)
  shippingFee      Float             @default(0)
  total            Float             @default(0)
  paidAmount       Float             @default(0)
  remainingAmount  Float             @default(0)
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  groomingSessions GroomingSession[]
  hotelStays       HotelStay[]
  items            OrderItem[]
  payments         OrderPayment[]
  branch           Branch?           @relation(fields: [branchId], references: [id])
  customer         Customer?         @relation(fields: [customerId], references: [id])
  staff            User              @relation(fields: [staffId], references: [id])
  transactions     Transaction[]

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model OrderPayment {
  id        String   @id @default(cuid())
  orderId   String
  method    String
  amount    Float
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_payments")
}

model OrderItem {
  id                String           @id @default(cuid())
  orderId           String
  productId         String?
  productVariantId  String?
  serviceId         String?
  serviceVariantId  String?
  petId             String?
  groomingSessionId String?
  hotelStayId       String?
  description       String
  quantity          Int
  unitPrice         Float
  discountItem      Float            @default(0)
  vatRate           Float            @default(0)
  subtotal          Float
  type              String
  createdAt         DateTime         @default(now())
  groomingSession   GroomingSession? @relation(fields: [groomingSessionId], references: [id])
  hotelStay         HotelStay?       @relation(fields: [hotelStayId], references: [id])
  order             Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product?         @relation(fields: [productId], references: [id])
  productVariant    ProductVariant?  @relation(fields: [productVariantId], references: [id])
  service           Service?         @relation(fields: [serviceId], references: [id])
  serviceVariant    ServiceVariant?  @relation(fields: [serviceVariantId], references: [id])

  @@index([orderId])
  @@index([hotelStayId])
  @@map("order_items")
}

model GroomingSession {
  id          String         @id @default(cuid())
  sessionCode String         @unique
  petId       String
  petName     String
  customerId  String?
  branchId    String?
  staffId     String?
  serviceId   String?
  orderId     String?
  status      GroomingStatus @default(PENDING)
  startTime   DateTime?
  endTime     DateTime?
  notes       String?
  price       Float?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  branch      Branch?        @relation(fields: [branchId], references: [id])
  pet         Pet            @relation(fields: [petId], references: [id])
  order       Order?         @relation(fields: [orderId], references: [id])
  staff       User?          @relation(fields: [staffId], references: [id])
  orderItems  OrderItem[]

  @@index([branchId])
  @@index([petId])
  @@index([orderId])
  @@index([status])
  @@index([createdAt])
  @@map("grooming_sessions")
}

model HotelRateTable {
  id           String        @id @default(cuid())
  name         String
  year         Int
  species      String?
  minWeight    Float?
  maxWeight    Float?
  lineType     HotelLineType @default(REGULAR)
  ratePerNight Float
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  isActive     Boolean       @default(true)
  hotelStays   HotelStay[]

  @@index([year, lineType, isActive])
  @@map("hotel_rate_tables")
}

model Cage {
  id          String        @id @default(cuid())
  name        String        @unique
  type        HotelLineType @default(REGULAR)
  description String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  hotelStays  HotelStay[]

  @@map("cages")
}

model HotelStay {
  id                String          @id @default(cuid())
  petId             String
  petName           String
  customerId        String?
  cageId            String?
  checkIn           DateTime
  checkOut          DateTime?
  estimatedCheckOut DateTime?
  status            HotelStatus     @default(BOOKED)
  lineType          HotelLineType   @default(REGULAR)
  price             Float?
  paymentStatus     PaymentStatus   @default(UNPAID)
  notes             String?
  rateTableId       String?
  orderId           String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  stayCode          String?         @unique
  branchId          String?
  checkOutActual    DateTime?
  dailyRate         Float           @default(0)
  depositAmount     Float           @default(0)
  petNotes          String?
  promotion         Float           @default(0)
  surcharge         Float           @default(0)
  totalPrice        Float           @default(0)
  branch            Branch?         @relation(fields: [branchId], references: [id])
  cage              Cage?           @relation(fields: [cageId], references: [id])
  customer          Customer?       @relation(fields: [customerId], references: [id])
  order             Order?          @relation(fields: [orderId], references: [id])
  pet               Pet             @relation(fields: [petId], references: [id])
  rateTable         HotelRateTable? @relation(fields: [rateTableId], references: [id])
  orderItems        OrderItem[]

  @@index([petId])
  @@index([customerId])
  @@index([branchId])
  @@index([cageId])
  @@index([status])
  @@index([paymentStatus])
  @@index([orderId])
  @@index([checkIn])
  @@index([estimatedCheckOut])
  @@map("hotel_stays")
}

model Supplier {
  id            String            @id @default(cuid())
  code          String?           @unique
  name          String
  phone         String?
  email         String?
  address       String?
  avatar        String?
  notes         String?
  documents     Json?
  monthTarget   Float?
  yearTarget    Float?
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  debt          Float             @default(0)
  creditBalance Float             @default(0)
  products      Product[]
  stockReceipts StockReceipt[]
  payments      SupplierPayment[]
  returns       SupplierReturn[]

  @@map("suppliers")
}

model StockReceipt {
  id                  String                      @id @default(cuid())
  receiptNumber       String                      @unique
  supplierId          String?
  branchId            String?
  status              String                      @default("DRAFT")
  receiptStatus       String                      @default("DRAFT")
  paymentStatus       PaymentStatus               @default(UNPAID)
  totalAmount         Float                       @default(0)
  totalReceivedAmount Float                       @default(0)
  totalReturnedAmount Float                       @default(0)
  paidAmount          Float                       @default(0)
  notes               String?
  receivedAt          DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?
  shortClosedAt       DateTime?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  items               StockReceiptItem[]
  paymentAllocations  SupplierPaymentAllocation[]
  receiveEvents       StockReceiptReceive[]
  supplierReturns     SupplierReturn[]
  branch              Branch?                     @relation(fields: [branchId], references: [id])
  supplier            Supplier?                   @relation(fields: [supplierId], references: [id])

  @@index([branchId])
  @@index([supplierId])
  @@index([status])
  @@index([receiptStatus])
  @@index([paymentStatus])
  @@map("stock_receipts")
}

model StockReceiptItem {
  id               String                    @id @default(cuid())
  receiptId        String
  productId        String
  productVariantId String?
  quantity         Int
  receivedQuantity Int                       @default(0)
  returnedQuantity Int                       @default(0)
  closedQuantity   Int                       @default(0)
  unitPrice        Float
  totalPrice       Float
  createdAt        DateTime                  @default(now())
  receiveItems     StockReceiptReceiveItem[]
  returnItems      SupplierReturnItem[]
  product          Product                   @relation(fields: [productId], references: [id])
  productVariant   ProductVariant?           @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  receipt          StockReceipt              @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([productVariantId])
  @@index([receiptId])
  @@map("stock_receipt_items")
}

model StockReceiptReceive {
  id            String                    @id @default(cuid())
  receiveNumber String                    @unique
  receiptId     String
  branchId      String?
  staffId       String?
  notes         String?
  receivedAt    DateTime                  @default(now())
  totalQuantity Int                       @default(0)
  totalAmount   Float                     @default(0)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  receipt       StockReceipt              @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  branch        Branch?                   @relation(fields: [branchId], references: [id])
  staff         User?                     @relation(fields: [staffId], references: [id])
  items         StockReceiptReceiveItem[]

  @@index([receiptId])
  @@index([branchId])
  @@index([staffId])
  @@index([receivedAt])
  @@map("stock_receipt_receives")
}

model StockReceiptReceiveItem {
  id               String              @id @default(cuid())
  receiveId        String
  receiptItemId    String
  productId        String
  productVariantId String?
  quantity         Int
  unitPrice        Float
  totalPrice       Float
  createdAt        DateTime            @default(now())
  receive          StockReceiptReceive @relation(fields: [receiveId], references: [id], onDelete: Cascade)
  receiptItem      StockReceiptItem    @relation(fields: [receiptItemId], references: [id], onDelete: Cascade)
  product          Product             @relation(fields: [productId], references: [id])
  productVariant   ProductVariant?     @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  @@index([receiveId])
  @@index([receiptItemId])
  @@index([productId])
  @@index([productVariantId])
  @@map("stock_receipt_receive_items")
}

model SupplierPayment {
  id                  String                      @id @default(cuid())
  paymentNumber       String                      @unique
  supplierId          String
  branchId            String?
  staffId             String?
  transactionId       String?                     @unique
  targetReceiptId     String?
  targetReceiptNumber String?
  amount              Float
  appliedAmount       Float                       @default(0)
  unappliedAmount     Float                       @default(0)
  paymentMethod       String?
  notes               String?
  paidAt              DateTime                    @default(now())
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  supplier            Supplier                    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  branch              Branch?                     @relation(fields: [branchId], references: [id])
  staff               User?                       @relation(fields: [staffId], references: [id])
  allocations         SupplierPaymentAllocation[]

  @@index([supplierId])
  @@index([branchId])
  @@index([staffId])
  @@index([targetReceiptId])
  @@index([paidAt])
  @@map("supplier_payments")
}

model SupplierPaymentAllocation {
  id        String          @id @default(cuid())
  paymentId String
  receiptId String
  amount    Float
  createdAt DateTime        @default(now())
  payment   SupplierPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  receipt   StockReceipt    @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([receiptId])
  @@map("supplier_payment_allocations")
}

model SupplierReturn {
  id             String                 @id @default(cuid())
  returnNumber   String                 @unique
  receiptId      String
  supplierId     String
  branchId       String?
  staffId        String?
  status         String                 @default("COMPLETED")
  notes          String?
  totalAmount    Float                  @default(0)
  creditedAmount Float                  @default(0)
  refundedAmount Float                  @default(0)
  returnedAt     DateTime               @default(now())
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  receipt        StockReceipt           @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  supplier       Supplier               @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  branch         Branch?                @relation(fields: [branchId], references: [id])
  staff          User?                  @relation(fields: [staffId], references: [id])
  items          SupplierReturnItem[]
  refunds        SupplierReturnRefund[]

  @@index([receiptId])
  @@index([supplierId])
  @@index([branchId])
  @@index([staffId])
  @@index([returnedAt])
  @@map("supplier_returns")
}

model SupplierReturnItem {
  id               String           @id @default(cuid())
  returnId         String
  receiptItemId    String
  productId        String
  productVariantId String?
  quantity         Int
  unitPrice        Float
  totalPrice       Float
  reason           String?
  createdAt        DateTime         @default(now())
  supplierReturn   SupplierReturn   @relation(fields: [returnId], references: [id], onDelete: Cascade)
  receiptItem      StockReceiptItem @relation(fields: [receiptItemId], references: [id], onDelete: Cascade)
  product          Product          @relation(fields: [productId], references: [id])
  productVariant   ProductVariant?  @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  @@index([returnId])
  @@index([receiptItemId])
  @@index([productId])
  @@index([productVariantId])
  @@map("supplier_return_items")
}

model SupplierReturnRefund {
  id               String         @id @default(cuid())
  refundNumber     String         @unique
  supplierReturnId String
  branchId         String?
  staffId          String?
  transactionId    String?        @unique
  amount           Float
  paymentMethod    String?
  notes            String?
  receivedAt       DateTime       @default(now())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  supplierReturn   SupplierReturn @relation(fields: [supplierReturnId], references: [id], onDelete: Cascade)
  branch           Branch?        @relation(fields: [branchId], references: [id])
  staff            User?          @relation(fields: [staffId], references: [id])

  @@index([supplierReturnId])
  @@index([branchId])
  @@index([staffId])
  @@index([receivedAt])
  @@map("supplier_return_refunds")
}

model StockTransaction {
  id          String   @id @default(cuid())
  productId   String
  type        String
  quantity    Int
  reason      String?
  referenceId String?
  createdAt   DateTime @default(now())
  product     Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("stock_transactions")
}

model BranchStock {
  id               String          @id @default(cuid())
  branchId         String
  productId        String?
  productVariantId String?
  stock            Int             @default(0)
  reservedStock    Int             @default(0)
  minStock         Int             @default(5)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  branch           Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product          Product?        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant          ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@unique([branchId, productId, productVariantId])
  @@index([branchId])
  @@index([productId])
  @@index([productVariantId])
  @@map("branch_stocks")
}

model Transaction {
  id            String          @id @default(cuid())
  voucherNumber String          @unique
  type          TransactionType
  amount        Float
  description   String
  category      String?
  orderId       String?
  paymentMethod String?
  branchId      String?
  branchName    String?
  refType       String?
  refId         String?
  refNumber     String?
  payerId       String?
  payerName     String?
  notes         String?
  tags          String?
  source        String          @default("OTHER")
  isManual      Boolean         @default(false)
  staffId       String?
  attachmentUrl String?
  date          DateTime        @default(now())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  order         Order?          @relation(fields: [orderId], references: [id])
  branch        Branch?         @relation(fields: [branchId], references: [id])
  staff         User?           @relation(fields: [staffId], references: [id])

  @@index([branchId])
  @@index([paymentMethod])
  @@index([refType])
  @@index([refId])
  @@index([refNumber])
  @@index([source])
  @@index([staffId])
  @@index([type])
  @@index([date])
  @@map("transactions")
}

model ShiftSession {
  id          String    @id @default(cuid())
  branchId    String
  staffId     String
  openAmount  Float     @default(0)
  closeAmount Float?
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  notes       String?
  status      String    @default("OPEN")
  branch      Branch    @relation(fields: [branchId], references: [id])
  staff       User      @relation(fields: [staffId], references: [id])

  @@index([status])
  @@index([branchId])
  @@map("shift_sessions")
}

model Role {
  id          String   @id @default(cuid())
  code        String   @unique @default(cuid())
  name        String   @unique
  description String?
  permissions String[]
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]

  @@map("roles")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  target    String?
  targetId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}

model SystemConfig {
  id                         String   @id @default(cuid())
  shopName                   String?
  shopPhone                  String?
  shopAddress                String?
  shopLogo                   String?
  taxRate                    Float?
  currency                   String?
  timezone                   String?
  email                      String?
  website                    String?
  updatedAt                  DateTime @updatedAt
  loyaltySpendPerPoint       Int?
  loyaltyPointValue          Int?
  loyaltyPointExpiryMonths   Int?
  loyaltyTierRetentionMonths Int?
  loyaltyTierRules           String?

  @@map("system_configs")
}

model Category {
  id            String     @id @default(cuid())
  name          String
  parentId      String?
  description   String?
  targetSpecies String?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  parent        Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children      Category[] @relation("CategoryToCategory")

  @@map("categories")
}

model Brand {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("brands")
}

model Unit {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("units")
}

model PriceBook {
  id        String   @id @default(cuid())
  name      String
  channel   String
  branchIds String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("price_books")
}

