// =============================================================
// PETSHOP SERVICE — Prisma Schema
// PostgreSQL · 24 Models · 2026-04-02
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==== ENUMS ====

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  COMPLETED
  REFUNDED
}

enum StaffRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum StaffStatus {
  PROBATION
  OFFICIAL
  LEAVE
  LEAVING
  RESIGNED
  QUIT
  WORKING
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum ServiceType {
  GROOMING
  HOTEL
  MEDICAL
  TRAINING
  DAYCARE
  OTHER
}

enum GroomingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum HotelStatus {
  BOOKED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum HotelLineType {
  REGULAR
  HOLIDAY
}

enum CustomerTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum PetGender {
  MALE
  FEMALE
  UNKNOWN
}

// ==== MODELS ====

model Branch {
  id          String   @id @default(cuid())
  name        String
  address     String?
  phone       String?
  email       String?
  description String?
  logo        String?
  taxCode     String?
  openTime    String?  @default("08:00")
  closeTime   String?  @default("21:00")
  isMain      Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  authorizedUsers User[]         @relation("UserAuthorizedBranches")
  orders          Order[]
  shiftSessions   ShiftSession[]

  @@map("branches")
}

model User {
  id                    String         @id @default(cuid())
  staffCode             String         @unique
  username              String         @unique
  passwordHash          String
  fullName              String
  legacyRole            StaffRole      @default(STAFF) @map("role")
  roleId                String?
  role                  Role?          @relation(fields: [roleId], references: [id])
  status                StaffStatus    @default(WORKING)
  employmentType        EmploymentType @default(FULL_TIME)
  phone                 String?
  email                 String?
  address               String?
  avatar                String?
  gender                String?
  dob                   DateTime?
  identityCode          String?
  emergencyContactTitle String?
  emergencyContactPhone String?
  shiftStart            String?
  shiftEnd              String?
  baseSalary            Float?
  spaCommissionRate     Float?
  branchId              String?
  joinDate              DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  branch             Branch?           @relation(fields: [branchId], references: [id])
  authorizedBranches Branch[]          @relation("UserAuthorizedBranches")
  orders             Order[]
  groomingSessions   GroomingSession[]
  activityLogs       ActivityLog[]
  transactions       Transaction[]
  shiftSessions      ShiftSession[]
  refreshTokens      RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model CustomerGroup {
  id          String   @id @default(cuid())
  name        String   @unique
  color       String   @default("#6366f1")
  pricePolicy String   @default("Giá lẻ")
  discount    Float    @default(0)
  description String?
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customers Customer[]

  @@map("customer_groups")
}

model Customer {
  id           String       @id @default(cuid())
  customerCode String       @unique
  fullName     String
  phone        String       @unique
  email        String?
  address      String?
  tier         CustomerTier @default(BRONZE)
  points       Int          @default(0)
  pointsUsed   Int          @default(0)
  groupId      String?
  notes        String?
  // Extended fields (ported from Petshop_Service_Management)
  taxCode      String?
  description  String?
  totalSpent   Float        @default(0)
  totalOrders  Int          @default(0)
  isActive     Boolean      @default(true)
  // Supplier dual-role fields
  isSupplier   Boolean      @default(false)
  supplierCode String?      @unique
  companyName  String?
  bankAccount  String?
  bankName     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  group  CustomerGroup? @relation(fields: [groupId], references: [id])
  pets   Pet[]
  orders Order[]

  @@index([phone])
  @@index([customerCode])
  @@index([isActive])
  @@map("customers")
}

model Pet {
  id               String            @id @default(cuid())
  petCode          String            @unique
  name             String
  species          String
  breed            String?
  gender           PetGender         @default(UNKNOWN)
  dateOfBirth      DateTime?
  weight           Float?
  color            String?
  microchipId      String?
  avatar           String?
  notes            String?
  allergies        String?
  temperament      String?
  isActive         Boolean           @default(true)
  customerId       String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  weightLogs       PetWeightLog[]
  vaccinations     PetVaccination[]
  healthNotes      PetHealthNote[]
  groomingSessions GroomingSession[]
  hotelStays       HotelStay[]

  @@index([customerId])
  @@index([petCode])
  @@map("pets")
}

model PetWeightLog {
  id        String   @id @default(cuid())
  petId     String
  weight    Float
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@map("pet_weight_logs")
}

model PetVaccination {
  id          String    @id @default(cuid())
  petId       String
  vaccineName String
  date        DateTime
  nextDueDate DateTime?
  notes       String?
  createdAt   DateTime  @default(now())

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@map("pet_vaccinations")
}

model PetHealthNote {
  id        String   @id @default(cuid())
  petId     String
  content   String
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@map("pet_health_notes")
}

model Product {
  id             String    @id @default(cuid())
  productCode    String?   @unique
  name           String
  sku            String?   @unique
  barcode        String?   @unique
  category       String?
  brand          String?
  description    String?
  price          Float
  costPrice      Float?
  wholesalePrice Float?
  stock          Int       @default(0)
  reservedStock  Int       @default(0)
  minStock       Int       @default(5)
  unit           String    @default("cái")
  weight         Float?
  vat            Float     @default(0)
  conversionRate Float?
  conversionUnit String?
  image          String?
  supplierId     String?
  importName     String?
  tags           String?
  attributes     String?
  isActive       Boolean   @default(true)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  supplier          Supplier?          @relation(fields: [supplierId], references: [id])
  variants          ProductVariant[]
  orderItems        OrderItem[]
  stockTransactions StockTransaction[]
  receiptItems      StockReceiptItem[]

  @@index([sku])
  @@index([category])
  @@map("products")
}

model ProductVariant {
  id              String    @id @default(cuid())
  productId       String
  name            String
  sku             String?   @unique
  barcode         String?
  price           Float
  costPrice       Float?
  stock           Int       @default(0)
  reservedStock   Int       @default(0)
  image           String?
  conversions     String?
  pricePolicies   String?
  priceBookPrices String?
  isActive        Boolean   @default(true)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

model Service {
  id          String      @id @default(cuid())
  name        String
  code        String?     @unique
  type        ServiceType @default(OTHER)
  description String?
  price       Float
  duration    Int?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  variants   ServiceVariant[]
  orderItems OrderItem[]

  @@map("services")
}

model ServiceVariant {
  id        String   @id @default(cuid())
  serviceId String
  name      String
  price     Float
  duration  Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service    Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([serviceId])
  @@map("service_variants")
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  customerId      String?
  customerName    String
  staffId         String
  branchId        String?
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  subtotal        Float         @default(0)
  discount        Float         @default(0)
  shippingFee     Float         @default(0)
  total           Float         @default(0)
  paidAmount      Float         @default(0)
  remainingAmount Float         @default(0)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer     Customer?      @relation(fields: [customerId], references: [id])
  staff        User           @relation(fields: [staffId], references: [id])
  branch       Branch?        @relation(fields: [branchId], references: [id])
  items        OrderItem[]
  payments     OrderPayment[]
  transactions Transaction[]

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model OrderPayment {
  id        String   @id @default(cuid())
  orderId   String
  method    String
  amount    Float
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_payments")
}

model OrderItem {
  id                String   @id @default(cuid())
  orderId           String
  productId         String?
  productVariantId  String?
  serviceId         String?
  serviceVariantId  String?
  petId             String?
  groomingSessionId String?
  hotelStayId       String?
  description       String
  quantity          Int
  unitPrice         Float
  discountItem      Float    @default(0)
  vatRate           Float    @default(0)
  subtotal          Float
  type              String // 'product' | 'service'
  createdAt         DateTime @default(now())

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product?        @relation(fields: [productId], references: [id])
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id])
  service        Service?        @relation(fields: [serviceId], references: [id])
  serviceVariant ServiceVariant? @relation(fields: [serviceVariantId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model GroomingSession {
  id         String         @id @default(cuid())
  petId      String
  petName    String
  customerId String?
  staffId    String?
  serviceId  String?
  orderId    String?
  status     GroomingStatus @default(PENDING)
  startTime  DateTime?
  endTime    DateTime?
  notes      String?
  price      Float?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  pet   Pet   @relation(fields: [petId], references: [id])
  staff User? @relation(fields: [staffId], references: [id])

  @@index([petId])
  @@index([status])
  @@index([createdAt])
  @@map("grooming_sessions")
}

model HotelRateTable {
  id           String        @id @default(cuid())
  name         String
  year         Int
  species      String?
  minWeight    Float?
  maxWeight    Float?
  lineType     HotelLineType @default(REGULAR)
  ratePerNight Float
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  hotelStays HotelStay[]

  @@map("hotel_rate_tables")
}

model Cage {
  id          String        @id @default(cuid())
  name        String        @unique // e.g., A-01, B-02
  type        HotelLineType @default(REGULAR)
  description String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  hotelStays HotelStay[]

  @@map("cages")
}

model HotelStay {
  id                String        @id @default(cuid())
  petId             String
  petName           String
  customerId        String?
  cageId            String?
  checkIn           DateTime
  checkOut          DateTime?
  estimatedCheckOut DateTime?
  status            HotelStatus   @default(BOOKED)
  lineType          HotelLineType @default(REGULAR)
  price             Float?
  paymentStatus     PaymentStatus @default(UNPAID)
  notes             String?
  rateTableId       String?
  orderId           String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  pet       Pet             @relation(fields: [petId], references: [id])
  cage      Cage?           @relation(fields: [cageId], references: [id])
  rateTable HotelRateTable? @relation(fields: [rateTableId], references: [id])

  @@index([petId])
  @@index([cageId])
  @@index([status])
  @@index([checkIn])
  @@map("hotel_stays")
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  isActive  Boolean  @default(true)
  debt      Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockReceipts StockReceipt[]
  products      Product[]

  @@map("suppliers")
}

model StockReceipt {
  id            String    @id @default(cuid())
  receiptNumber String    @unique
  supplierId    String?
  status        String    @default("DRAFT")
  totalAmount   Float     @default(0)
  paidAmount    Float     @default(0)
  notes         String?
  receivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  supplier Supplier?          @relation(fields: [supplierId], references: [id])
  items    StockReceiptItem[]

  @@map("stock_receipts")
}

model StockReceiptItem {
  id         String   @id @default(cuid())
  receiptId  String
  productId  String
  quantity   Int
  unitPrice  Float
  totalPrice Float
  createdAt  DateTime @default(now())

  receipt StockReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])

  @@map("stock_receipt_items")
}

model StockTransaction {
  id          String   @id @default(cuid())
  productId   String
  type        String // 'IN' | 'OUT' | 'ADJUST' | 'RETURN'
  quantity    Int
  reason      String?
  referenceId String?
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("stock_transactions")
}

model Transaction {
  id            String          @id @default(cuid())
  voucherNumber String          @unique
  type          TransactionType
  amount        Float
  description   String
  category      String?
  orderId       String?
  staffId       String?
  date          DateTime        @default(now())
  createdAt     DateTime        @default(now())

  order Order? @relation(fields: [orderId], references: [id])
  staff User?  @relation(fields: [staffId], references: [id])

  @@index([type])
  @@index([date])
  @@map("transactions")
}

model ShiftSession {
  id          String    @id @default(cuid())
  branchId    String
  staffId     String
  openAmount  Float     @default(0)
  closeAmount Float?
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  notes       String?
  status      String    @default("OPEN") // OPEN | CLOSED

  branch Branch @relation(fields: [branchId], references: [id])
  staff  User   @relation(fields: [staffId], references: [id])

  @@index([status])
  @@index([branchId])
  @@map("shift_sessions")
}

model Role {
  id          String   @id @default(cuid())
  code        String   @unique @default(cuid())
  name        String   @unique
  description String?
  permissions String[] // string array of permission keys
  isSystem    Boolean  @default(false)
  users       User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roles")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  target    String?
  targetId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}

model SystemConfig {
  id          String  @id @default(cuid())
  shopName    String?
  shopPhone   String?
  shopAddress String?
  shopLogo    String?
  taxRate     Float?
  currency    String?
  timezone    String?
  email       String?
  website     String?

  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

model Category {
  id          String     @id @default(cuid())
  name        String
  parentId    String?
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parent      Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryToCategory")

  @@map("categories")
}

model Brand {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("brands")
}

model Unit {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("units")
}

model PriceBook {
  id        String   @id @default(cuid())
  name      String
  channel   String
  branchIds String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("price_books")
}
