// =============================================================================
// @file     schema.prisma — Petshop Management V2 Database Schema
// @encoding utf-8  ← This file and ALL seed/migration files MUST be UTF-8.
//                    AI tools: always open with encoding='utf-8'.
//                    Never save as Latin-1 / cp1252 / Windows-1252.
// @db       PostgreSQL — collation UTF-8 is enforced at the server level.
//           String fields storing Vietnamese text use TEXT / VARCHAR,
//           which inherits the database-level UTF-8 collation.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Branch {
  id                    String                 @id @default(cuid())
  code                  String                 @unique
  name                  String
  address               String?
  phone                 String?
  email                 String?
  description           String?
  logo                  String?
  taxCode               String?
  openTime              String?                @default("08:00")
  closeTime             String?                @default("21:00")
  isMain                Boolean                @default(false)
  isActive              Boolean                @default(true)
  cashReserveTargetAmount Float                @default(2000000)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  branchStocks          BranchStock[]
  customers             Customer[]
  groomingSessions      GroomingSession[]
  hotelStays            HotelStay[]
  orders                Order[]
  pets                  Pet[]
  shiftSessions         ShiftSession[]
  cashVaultEntries      CashVaultEntry[]
  stockReceipts         StockReceipt[]
  stockReceiptReceives  StockReceiptReceive[]
  supplierPayments      SupplierPayment[]
  supplierReturns       SupplierReturn[]
  supplierReturnRefunds SupplierReturnRefund[]
  productSalesDaily     ProductSalesDaily[]
  paymentIntents        PaymentIntent[]
  transactions          Transaction[]
  users                 User[]
  authorizedUsers       User[]                 @relation("UserAuthorizedBranches")
  stockCountSessions    StockCountSession[]
  hotelPriceRules       HotelPriceRule[]
  staffSchedules        StaffSchedule[]
  attendanceRecords     AttendanceRecord[]
  leaveRequests         LeaveRequest[]
  payrollPeriods        PayrollPeriod[]
  stockTransactions     StockTransaction[]
  equipments            Equipment[]
  equipmentLocationPresets EquipmentLocationPreset[]

  @@map("branches")
}

model User {
  id                    String                 @id @default(cuid())
  staffCode             String                 @unique
  username              String                 @unique
  passwordHash          String
  googleId              String?                @unique
  googleEmail           String?
  googleAvatar          String?
  fullName              String
  legacyRole            StaffRole              @default(STAFF) @map("role")
  roleId                String?
  status                StaffStatus            @default(WORKING)
  employmentType        EmploymentType         @default(FULL_TIME)
  phone                 String?
  email                 String?
  address               String?
  avatar                String?
  gender                String?
  dob                   DateTime?
  identityCode          String?
  emergencyContactTitle String?
  emergencyContactPhone String?
  shiftStart            String?
  shiftEnd              String?
  baseSalary            Float?
  spaCommissionRate     Float?
  branchId              String?
  joinDate              DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  activityLogs          ActivityLog[]
  groomingSessions      GroomingSession[]
  hotelCreatedStays     HotelStay[]
  orders                Order[]
  refreshTokens         RefreshToken[]
  storedAssets          StoredAsset[]
  shiftSessions         ShiftSession[]
  cashVaultEntries      CashVaultEntry[]     @relation("CashVaultEntryPerformedBy")
  stockReceiptReceives  StockReceiptReceive[]
  supplierPayments      SupplierPayment[]
  supplierReturns       SupplierReturn[]
  supplierReturnRefunds SupplierReturnRefund[]
  transactions          Transaction[]
  branch                Branch?                @relation(fields: [branchId], references: [id])
  role                  Role?                  @relation(fields: [roleId], references: [id])
  authorizedBranches    Branch[]               @relation("UserAuthorizedBranches")
  documents             EmployeeDocument[]
  stockCountSessions    StockCountSession[]    @relation("StockCountSessionCreatedBy")
  approvedStockCountSessions StockCountSession[] @relation("StockCountSessionApprovedBy")
  stockCountShiftSessions StockCountShiftSession[] @relation("StockCountShiftCountedBy")
  approvedOrders          Order[]              @relation("OrderApprover")
  stockExportOrders       Order[]              @relation("OrderStockExporter")
  settledOrders           Order[]              @relation("OrderSettler")
  orderTimelines          OrderTimeline[]
  groomingTimelines       GroomingTimeline[]
  hotelStayTimelines      HotelStayTimeline[]
  staffSchedules          StaffSchedule[]
  attendanceRecords       AttendanceRecord[]
  reviewedAttendances     AttendanceRecord[]     @relation("AttendanceReviewer")
  leaveRequests           LeaveRequest[]
  approvedLeaves          LeaveRequest[]         @relation("LeaveApprover")
  payrollSlips            PayrollSlip[]
  approvedPayrolls        PayrollPeriod[]        @relation("PayrollApprover")
  faceEmbeddings          FaceEmbedding[]
  stockTransactions       StockTransaction[]
  createdEquipments       Equipment[]            @relation("EquipmentCreatedBy")
  updatedEquipments       Equipment[]            @relation("EquipmentUpdatedBy")
  equipmentHistoryEntries EquipmentHistory[]     @relation("EquipmentHistoryActor")
  
  assignedGroomingSessions GroomingSession[]    @relation("GroomingAssignedStaff")

  @@map("users")
}

// ============================================================================
// Employee Document Management
// ============================================================================

model EmployeeDocument {
  id          String   @id @default(cuid())
  userId      String
  type        DocumentType
  fileName    String
  fileUrl     String
  fileSize    Int      // in bytes
  mimeType    String
  description String?
  uploadedAt  DateTime @default(now())
  uploadedBy  String
  expiresAt   DateTime?
  isActive    Boolean  @default(true)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([isActive])
  @@map("employee_documents")
}

enum DocumentType {
  CCCD_FRONT          // CCCD mặt trước
  CCCD_BACK           // CCCD mặt sau
  APPLICATION         // Hồ sơ xin việc
  CERTIFICATE         // Bằng cấp / Chứng chỉ
  CONTRACT            // Hợp đồng lao động
  HEALTH_CERT         // Giấy khám sức khỏe
  TRAINING_CERT       // Chứng chỉ đào tạo
  OTHER               // Tài liệu khác
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model CustomerGroup {
  id          String     @id @default(cuid())
  name        String     @unique
  color       String     @default("#6366f1")
  pricePolicy String     @default("Giá lẻ")
  priceBookId String?
  discount    Float      @default(0)
  description String?
  isActive    Boolean    @default(true)
  isDefault   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  customers   Customer[]
  priceBook   PriceBook? @relation(fields: [priceBookId], references: [id], onDelete: SetNull)

  @@index([priceBookId])
  @@map("customer_groups")
}

model Customer {
  id           String         @id @default(cuid())
  customerCode String         @unique
  fullName     String
  phone        String         @unique
  email        String?
  address      String?
  tier         CustomerTier   @default(BRONZE)
  points       Int            @default(0)
  pointsUsed   Int            @default(0)
  branchId     String?
  groupId      String?
  notes        String?
  taxCode      String?
  description  String?
  debt         Float          @default(0)
  totalSpent   Float          @default(0)
  totalOrders  Int            @default(0)
  isActive     Boolean        @default(true)
  isSupplier   Boolean        @default(false)
  supplierCode String?        @unique
  companyName         String?
  companyAddress      String?
  representativeName  String?
  representativePhone String?
  bankAccount         String?
  bankName            String?
  createdAt           DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  branch       Branch?        @relation(fields: [branchId], references: [id])
  group        CustomerGroup? @relation(fields: [groupId], references: [id])
  hotelStays   HotelStay[]
  orders       Order[]
  pets         Pet[]

  @@index([phone])
  @@index([customerCode])
  @@index([branchId])
  @@index([isActive])
  @@map("customers")
}

model Pet {
  id               String            @id @default(cuid())
  petCode          String            @unique
  name             String
  species          String
  breed            String?
  gender           PetGender         @default(UNKNOWN)
  dateOfBirth      DateTime?
  weight           Float?
  color            String?
  microchipId      String?
  avatar           String?
  notes            String?
  branchId         String?
  customerId       String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  allergies        String?
  isActive         Boolean           @default(true)
  temperament      String?
  groomingSessions GroomingSession[]
  hotelStays       HotelStay[]
  healthNotes      PetHealthNote[]
  vaccinations     PetVaccination[]
  weightLogs       PetWeightLog[]
  timeline         PetTimeline[]
  branch           Branch?           @relation(fields: [branchId], references: [id])
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([customerId])
  @@index([petCode])
  @@map("pets")
}

model PetWeightLog {
  id        String   @id @default(cuid())
  petId     String
  weight    Float
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@map("pet_weight_logs")
}

model PetVaccination {
  id          String    @id @default(cuid())
  petId       String
  vaccineName String
  date        DateTime
  nextDueDate DateTime?
  notes       String?
  photoUrl    String?
  createdAt   DateTime  @default(now())
  pet         Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@map("pet_vaccinations")
}

model PetHealthNote {
  id        String   @id @default(cuid())
  petId     String
  content   String
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@map("pet_health_notes")
}

model PetTimeline {
  id        String   @id @default(cuid())
  petId     String
  action    String   // 'INFO_UPDATED' | 'WEIGHT_UPDATED' | 'VACCINATION_ADDED' | 'CREATED'
  note      String?
  metadata  Json?    // { changes: [{ field, label, from, to }] } hoặc { weight, notes }
  createdAt DateTime @default(now())
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@index([createdAt])
  @@map("pet_timelines")
}

model Product {
  id                  String                    @id @default(cuid())
  name                String
  sku                 String?                   @unique
  groupCode           String?                   @unique
  barcode             String?                   @unique
  category            String?
  targetSpecies       String?
  brand               String?
  description         String?
  price               Float
  costPrice           Float?
  minStock            Int                       @default(5)
  unit                String                    @default("cái")
  image               String?
  isActive            Boolean                   @default(true)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  attributes          String?
  conversionRate      Float?
  conversionUnit      String?
  deletedAt           DateTime?
  importName          String?
  supplierId          String?
  tags                String?
  vat                 Float                     @default(0)
  weight              Float?
  wholesalePrice      Float?
  lastCountShift      StockCountShift?        // Ca kiểm gần nhất đã gán
  branchStocks        BranchStock[]
  orderItems          OrderItem[]
  variants            ProductVariant[]
  supplier            Supplier?                 @relation(fields: [supplierId], references: [id])
  receiptItems        StockReceiptItem[]
  receiveItems        StockReceiptReceiveItem[]
  salesDaily          ProductSalesDaily[]
  stockTransactions   StockTransaction[]
  supplierReturnItems SupplierReturnItem[]
  stockCountItems     StockCountItem[]

  @@index([sku])
  @@index([groupCode])
  @@index([category])
  @@map("products")
}

model ProductVariant {
  id                  String                    @id @default(cuid())
  productId           String
  name                String
  variantLabel        String?
  unitLabel           String?
  sku                 String?                   @unique
  price               Float
  isActive            Boolean                   @default(true)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  barcode             String?
  conversions         String?
  costPrice           Float?
  deletedAt           DateTime?
  image               String?
  priceBookPrices     String?
  pricePolicies       String?
  branchStocks        BranchStock[]
  orderItems          OrderItem[]
  receiptItems        StockReceiptItem[]
  receiveItems        StockReceiptReceiveItem[]
  salesDaily          ProductSalesDaily[]
  supplierReturnItems SupplierReturnItem[]
  stockCountItems     StockCountItem[]
  stockTransactions   StockTransaction[] @relation("StockTransactionActionVariant")
  sourceStockTransactions StockTransaction[] @relation("StockTransactionSourceVariant")
  product             Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_variants")
}

model Service {
  id          String           @id @default(cuid())
  name        String
  code        String?          @unique
  type        ServiceType      @default(OTHER)
  description String?
  price       Float
  duration    Int?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  orderItems  OrderItem[]
  variants    ServiceVariant[]

  @@map("services")
}

model ServiceVariant {
  id         String      @id @default(cuid())
  serviceId  String
  name       String
  price      Float
  duration   Int?
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orderItems OrderItem[]
  service    Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("service_variants")
}

model Order {
  id               String            @id @default(cuid())
  orderNumber      String            @unique
  customerId       String?
  customerName     String
  staffId          String
  branchId         String?
  status           OrderStatus       @default(PENDING)
  paymentStatus    PaymentStatus     @default(UNPAID)
  subtotal         Float             @default(0)
  discount         Float             @default(0)
  shippingFee      Float             @default(0)
  total            Float             @default(0)
  paidAmount       Float             @default(0)
  remainingAmount  Float             @default(0)
  notes            String?
  createdAt        DateTime          @default(now())
  completedAt      DateTime?
  updatedAt        DateTime          @updatedAt

  // Workflow tracking fields
  approvedAt       DateTime?
  approvedBy       String?
  stockExportedAt  DateTime?
  stockExportedBy  String?
  settledAt        DateTime?
  settledBy        String?

  // Đổi hàng: link đến return request gốc (nếu đồy là đơn exchange)
  linkedReturnId   String?           // OrderReturnRequest.id
  creditAmount     Float             @default(0) // Số tiền credit từ đơn cũ

  groomingSessions GroomingSession[]
  hotelStays       HotelStay[]
  items            OrderItem[]
  payments         OrderPayment[]
  paymentIntents   PaymentIntent[]
  bankTransactions BankTransaction[]
  webhookEvents    PaymentWebhookEvent[]
  timeline         OrderTimeline[]
  returnRequests   OrderReturnRequest[]
  branch           Branch?           @relation(fields: [branchId], references: [id])
  customer         Customer?         @relation(fields: [customerId], references: [id])
  staff            User              @relation(fields: [staffId], references: [id])
  transactions     Transaction[]
  approvedByUser   User?             @relation("OrderApprover", fields: [approvedBy], references: [id])
  stockExportUser  User?             @relation("OrderStockExporter", fields: [stockExportedBy], references: [id])
  settledUser      User?             @relation("OrderSettler", fields: [settledBy], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([completedAt])
  @@index([approvedBy])
  @@index([stockExportedBy])
  @@index([settledBy])
  @@map("orders")
}

model OrderPayment {
  id        String   @id @default(cuid())
  orderId   String
  method    String
  amount    Float
  note      String?
  paymentAccountId    String?
  paymentAccountLabel String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([paymentAccountId])
  @@map("order_payments")
}

// ============================================================================
// Order Timeline / Lịch sử thay đổi đơn hàng
// ============================================================================

model OrderTimeline {
  id            String      @id @default(cuid())
  orderId       String
  action        OrderAction
  fromStatus    String?
  toStatus      String?
  note          String?
  performedBy   String
  metadata      Json?
  createdAt     DateTime    @default(now())

  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  performedByUser User      @relation(fields: [performedBy], references: [id])

  @@index([orderId])
  @@index([performedBy])
  @@index([createdAt])
  @@index([action])
  @@map("order_timelines")
}

model GroomingTimeline {
  id            String      @id @default(cuid())
  sessionId     String      @map("groomingSessionId")
  action        String
  fromStatus    String?
  toStatus      String?
  note          String?
  performedBy   String
  metadata      Json?
  createdAt     DateTime    @default(now())

  session       GroomingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  performedByUser User      @relation(fields: [performedBy], references: [id])

  @@index([sessionId])
  @@index([performedBy])
  @@index([createdAt])
  @@map("grooming_timelines")
}

model HotelStayTimeline {
  id            String      @id @default(cuid())
  stayId        String      @map("hotelStayId")
  action        String
  fromStatus    String?
  toStatus      String?
  note          String?
  performedBy   String
  metadata      Json?
  createdAt     DateTime    @default(now())

  stay          HotelStay   @relation(fields: [stayId], references: [id], onDelete: Cascade)
  performedByUser User      @relation(fields: [performedBy], references: [id])

  @@index([stayId])
  @@index([performedBy])
  @@index([createdAt])
  @@map("hotel_stay_timelines")
}

model OrderItem {
  id                String           @id @default(cuid())
  orderId           String
  sku               String?
  productId         String?
  productVariantId  String?
  serviceId         String?
  serviceVariantId  String?
  petId             String?
  groomingSessionId String?
  hotelStayId       String?
  description       String
  quantity          Float
  unitPrice         Float
  discountItem      Float            @default(0)
  vatRate           Float            @default(0)
  subtotal          Float
  pricingSnapshot   Json?
  type              String
  isTemp            Boolean          @default(false)
  tempLabel         String?
  stockExportedAt   DateTime?        // Thời điểm xuất kho item này (Phương án B)
  stockExportedBy   String?          // Staff thực hiện xuất kho item này
  createdAt         DateTime         @default(now())
  groomingSession   GroomingSession? @relation(fields: [groomingSessionId], references: [id])
  hotelStay         HotelStay?       @relation(fields: [hotelStayId], references: [id])
  order             Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product?         @relation(fields: [productId], references: [id])
  productVariant    ProductVariant?  @relation(fields: [productVariantId], references: [id])
  service           Service?         @relation(fields: [serviceId], references: [id])
  serviceVariant    ServiceVariant?  @relation(fields: [serviceVariantId], references: [id])
  returnItems       OrderReturnItem[]

  @@index([orderId])
  @@index([hotelStayId])
  @@map("order_items")
}

// ============================================================================
// Order Return Request / Yêu cầu đổi trả hàng
// ============================================================================

model OrderReturnRequest {
  id            String             @id @default(cuid())
  orderId       String
  type          String             // 'PARTIAL' | 'FULL'
  reason        String?
  refundAmount  Float?             @default(0)
  refundMethod  String?            // 'CASH' | 'BANK' | etc.
  status        String             @default("PENDING") // 'PENDING' | 'APPROVED'
  performedBy   String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  order         Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items         OrderReturnItem[]

  @@index([orderId])
  @@index([performedBy])
  @@index([createdAt])
  @@map("order_return_requests")
}

model OrderReturnItem {
  id              String             @id @default(cuid())
  returnRequestId String
  orderItemId     String
  quantity        Float
  action          String             // 'EXCHANGE' | 'RETURN'
  reason          String?
  createdAt       DateTime           @default(now())
  returnRequest   OrderReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItem       OrderItem          @relation(fields: [orderItemId], references: [id])

  @@index([returnRequestId])
  @@index([orderItemId])
  @@map("order_return_items")
}

model ProductSalesDaily {
  id               String          @id @default(cuid())
  date             DateTime
  branchId         String?
  branchScope      String
  productId        String
  productVariantId String?
  salesKey         String
  quantitySold     Int             @default(0)
  revenue          Float           @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  branch           Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  product          Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  @@unique([date, branchScope, salesKey])
  @@index([branchId, date])
  @@index([productId, date])
  @@index([productVariantId, date])
  @@index([salesKey, date])
  @@map("product_sales_daily")
}

model GroomingSession {
  id          String         @id @default(cuid())
  sessionCode String         @unique
  petId       String
  petName     String
  customerId  String?
  branchId    String?
  staffId     String?
  serviceId   String?
  orderId     String?
  status      GroomingStatus @default(PENDING)
  startTime   DateTime?
  endTime     DateTime?
  notes       String?
  price       Float?
  surcharge   Float?         @default(0)
  packageCode String?
  weightAtBooking Float?
  weightBandId String?
  pricingSnapshot Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  branch      Branch?        @relation(fields: [branchId], references: [id])
  pet         Pet            @relation(fields: [petId], references: [id])
  order       Order?         @relation(fields: [orderId], references: [id])
  staff       User?          @relation(fields: [staffId], references: [id])
  assignedStaff User[]       @relation("GroomingAssignedStaff")
  weightBand  ServiceWeightBand? @relation(fields: [weightBandId], references: [id])
  orderItems  OrderItem[]
  timeline    GroomingTimeline[]

  @@index([branchId])
  @@index([petId])
  @@index([orderId])
  @@index([status])
  @@index([weightBandId])
  @@index([createdAt])
  @@map("grooming_sessions")
}

model ServiceWeightBand {
  id              String           @id @default(cuid())
  serviceType     ServiceType
  species         String?
  label           String
  minWeight       Float
  maxWeight       Float?
  sortOrder       Int              @default(0)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  spaPriceRules   SpaPriceRule[]
  groomingSessions GroomingSession[]
  hotelPriceRules HotelPriceRule[]
  hotelStays      HotelStay[]
  hotelChargeLines HotelStayChargeLine[]

  @@index([serviceType, species, isActive, sortOrder])
  @@map("service_weight_bands")
}

model HotelRateTable {
  id           String        @id @default(cuid())
  name         String
  year         Int
  species      String?
  minWeight    Float?
  maxWeight    Float?
  lineType     HotelLineType @default(REGULAR)
  ratePerNight Float
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  isActive     Boolean       @default(true)
  hotelStays   HotelStay[]

  @@index([year, lineType, isActive])
  @@map("hotel_rate_tables")
}

model Cage {
  id          String        @id @default(cuid())
  name        String        @unique
  type        HotelLineType @default(REGULAR)
  description String?
  position    Int           @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  hotelStays  HotelStay[]

  @@map("cages")
}

model HotelPriceRule {
  id            String            @id @default(cuid())
  sku           String?           // Editable SKU
  year          Int
