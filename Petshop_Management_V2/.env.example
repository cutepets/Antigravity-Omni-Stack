# ============================================
# PETSHOP SERVICE — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

NODE_ENV=development

# ---- Database ----
DATABASE_URL="postgresql://petshop:petshop_secret@localhost:5432/petshop_db"

# ---- JWT ----
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-here"
JWT_REFRESH_SECRET="your-refresh-secret-key-min-32-chars-here"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ---- Bootstrap Admin ----
# Used only when the database has no users. Required in production.
BOOTSTRAP_ADMIN_PASSWORD="change-this-before-production"

# ---- Server Ports ----
API_PORT=3001
WORKER_PORT=3002
WEB_PORT=3000

# ---- Redis ----
REDIS_URL="redis://localhost:6379"

# ---- CORS ----
CORS_ORIGINS="http://localhost:3000"
TRUST_PROXY="loopback, linklocal, uniquelocal"

# ---- Upload ----
UPLOAD_DIR="./uploads"
PRIVATE_UPLOAD_DIR="./storage/private"
MAX_FILE_SIZE=52428800
